# 🌌 Antispace Environment Configuration Template
# Copy this file to '.env' and fill in your keys.

# Gemini API Key (Recommended for high-fidelity responses)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (Alternative fallback LLM models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Hugging Face Token (Alternative option if using Hugging Face models)
HF_TOKEN=your_huggingface_token_here

# Qdrant Database Host (Leave default if running locally via docker)
QDRANT_HOST=http://localhost:6333

# Qdrant Cloud Credentials (Optional: For cloud production hosting)
# QDRANT_URL=https://xxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=your_qdrant_cloud_api_key_here

# Cohere API Key (Optional: For cloud-based premium reranking)
# COHERE_API_KEY=your_cohere_api_key_here

# Langfuse Observability API Keys (Optional: For LLM analytics tracing)
# LANGFUSE_PUBLIC_KEY=lf-pub-xxxxxxxxxxxxxxxxxxxxxxxx
# LANGFUSE_SECRET_KEY=lf-sec-xxxxxxxxxxxxxxxxxxxxxxxx
# LANGFUSE_HOST=https://cloud.langfuse.com

